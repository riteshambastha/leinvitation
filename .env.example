# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # keep secret, server-only

# ── Resend (email delivery) ───────────────────────────────────────────────────
# Get from: resend.com → API Keys (free plan: 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App config ────────────────────────────────────────────────────────────────
# Your production URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Email sender address — must be a verified domain in Resend
EMAIL_FROM=invites@yourdomain.com
